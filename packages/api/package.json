{
  "name": "@metabox/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./services": {
      "types": "./src/services/index.ts",
      "default": "./dist/services/index.js"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@google/generative-ai": "^0.24.0",
    "@metabox/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.2",
    "openai": "^4.90.0",
    "pg": "^8.20.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/pg": "^8.18.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
