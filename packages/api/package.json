{
  "name": "@metabox/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./services": {
      "types": "./src/services/index.ts",
      "default": "./dist/services/index.js"
    },
    "./queues": {
      "types": "./src/queues/index.ts",
      "default": "./dist/queues/index.js"
    },
    "./db": {
      "types": "./src/db.ts",
      "default": "./dist/db.js"
    },
    "./ai/image": {
      "types": "./src/ai/image/factory.ts",
      "default": "./dist/ai/image/factory.js"
    },
    "./ai/video": {
      "types": "./src/ai/video/factory.ts",
      "default": "./dist/ai/video/factory.js"
    },
    "./ai/audio": {
      "types": "./src/ai/audio/factory.ts",
      "default": "./dist/ai/audio/factory.js"
    },
    "./services/s3": {
      "types": "./src/services/s3.service.ts",
      "default": "./dist/services/s3.service.js"
    },
    "./utils/mp4-duration": {
      "types": "./src/utils/mp4-duration.ts",
      "default": "./dist/utils/mp4-duration.js"
    },
    "./utils/download-token": {
      "types": "./src/utils/download-token.ts",
      "default": "./dist/utils/download-token.js"
    },
    "./services/user-avatar": {
      "types": "./src/services/user-avatar.service.ts",
      "default": "./dist/services/user-avatar.service.js"
    },
    "./ai/avatar/heygen": {
      "types": "./src/ai/avatar/heygen.avatar.adapter.ts",
      "default": "./dist/ai/avatar/heygen.avatar.adapter.js"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.1011.0",
    "@aws-sdk/s3-request-presigner": "^3.1011.0",
    "@fal-ai/client": "^1.5.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.1.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@google/generative-ai": "^0.24.0",
    "@metabox/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@sentry/node": "^10.43.0",
    "bullmq": "^5.56.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.2",
    "ioredis": "^5.6.1",
    "openai": "^4.90.0",
    "pg": "^8.20.0",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "replicate": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/pg": "^8.18.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
