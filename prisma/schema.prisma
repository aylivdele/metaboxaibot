generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

// ─────────────────────────────────────────────
// Пользователь
// ─────────────────────────────────────────────
model User {
  id           BigInt   @id                    // Telegram user ID
  username     String?
  firstName    String?
  lastName     String?
  language     String   @default("en")
  role         Role     @default(USER)
  tokenBalance Decimal  @default(5.50)         @db.Decimal(12, 4)
  isNew        Boolean  @default(true)
  isBlocked    Boolean  @default(false)
  referredById BigInt?
  metaboxUserId      String? // UUID пользователя в Metabox (после привязки)
  metaboxReferralCode String? // Реферальный код Metabox (кешируется при привязке)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referredBy   User?              @relation("Referrals", fields: [referredById], references: [id])
  referrals    User[]             @relation("Referrals")
  dialogs      Dialog[]
  transactions TokenTransaction[]
  userState    UserState?
  uploads      UserUpload[]
  userAvatars  UserAvatar[]

  @@map("users")
}

// Состояние FSM бота для пользователя
model UserState {
  userId    BigInt  @id
  state     String  @default("IDLE")          // IDLE | MAIN_MENU | GPT_SECTION | GPT_ACTIVE | ...
  section   String? // gpt | design | audio | video
  gptModelId String? // текущая выбранная GPT-модель

  // Активный диалог для каждого раздела (хранится независимо)
  gptDialogId    String?
  designDialogId String?
  audioDialogId  String?
  videoDialogId  String?

  // Выбранная модель для каждого медиа-раздела (не зависит от диалога)
  designModelId  String?
  audioModelId   String?
  videoModelId   String?

  // Референс для img2img: Message.id выбранного изображения (one-shot, сбрасывается после использования)
  designRefMessageId String?

  // Референс-фото для D-ID lip-sync: Telegram file URL (one-shot, сбрасывается после использования)
  videoRefImageUrl String?

  // Референс-видео для D-ID driver_url: Telegram file URL (one-shot, сбрасывается после использования)
  videoRefDriverUrl String?

  // Голосовое сообщение для HeyGen audio voice: Telegram file URL (one-shot, сбрасывается после использования)
  videoRefVoiceUrl String?

  // Настройки генерации изображений: { [modelId]: { aspectRatio: string } }
  imageSettings Json?

  // Настройки генерации видео: { [modelId]: { aspectRatio?: string; duration?: number } }
  videoSettings Json?

  // Произвольные настройки моделей: { [modelId]: { [key]: string | number | boolean | null } }
  modelSettings Json?

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_states")
}

// ─────────────────────────────────────────────
// Диалоги
// ─────────────────────────────────────────────
model Dialog {
  id       String  @id @default(cuid())
  userId   BigInt
  section  String  // gpt | design | audio | video
  modelId  String  // gpt-4o | claude-sonnet | midjourney | kling | etc.
  title    String?
  isDeleted Boolean @default(false)

  // ── Стратегия хранения контекста ────────────────────────────────────────
  // "provider_chain"  — OpenAI Responses API: цепочка через previous_response_id
  // "provider_thread" — OpenAI Assistants: сервер хранит всю историю в Thread
  // "db_history"      — Anthropic, Gemini и др.: история из БД, последние N сообщений
  contextStrategy        String  @default("db_history")
  providerThreadId       String? // OpenAI Assistants: thread_id
  providerLastResponseId String? // OpenAI Responses API: последний response_id

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@index([userId, section])
  @@map("dialogs")
}

model Message {
  id                String  @id @default(cuid())
  dialogId          String
  role              String  // user | assistant
  content           String
  mediaUrl          String?
  mediaType         String? // image | video | audio
  tokensUsed        Decimal @default(0) @db.Decimal(10, 4)
  providerMessageId String? // OpenAI Assistants: message_id (для управления историей)

  createdAt DateTime @default(now())

  dialog Dialog @relation(fields: [dialogId], references: [id], onDelete: Cascade)

  @@index([dialogId, createdAt])
  @@map("messages")
}

// ─────────────────────────────────────────────
// Токены
// ─────────────────────────────────────────────
model TokenTransaction {
  id     String  @id @default(cuid())
  userId BigInt
  amount Decimal @db.Decimal(12, 4)           // положительное = пополнение, отрицательное = списание
  type   String  // credit | debit
  reason      String  // welcome_bonus | ai_usage | purchase | referral_bonus | admin | metabox_purchase
  description String? // Человекочитаемое описание (напр. "Подписка PRO (M3)")

  // Метаданные для разных типов
  modelId  String? // при ai_usage
  dialogId String? // при ai_usage

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("token_transactions")
}

// ─────────────────────────────────────────────
// Задачи генерации (async queue)
// ─────────────────────────────────────────────
model GenerationJob {
  id       String @id @default(cuid())
  userId   BigInt
  dialogId String
  section  String // image | video | audio
  modelId  String
  status   String @default("pending") // pending | processing | done | failed

  prompt    String
  inputData Json?  // доп. параметры (размер, стиль и т.д.)
  outputUrl String?
  s3Key     String? // path within S3 bucket — null if upload skipped
  error     String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([userId])
  @@index([status])
  @@map("generation_jobs")
}

// ─────────────────────────────────────────────
// Загрузки пользователей (голоса, аудио)
// ─────────────────────────────────────────────
model UserUpload {
  id        String   @id @default(cuid())
  userId    BigInt
  type      String   // "voice" | "audio"
  name      String
  url       String   // публичный URL (S3 или Telegram)
  s3Key     String?  // ключ в S3, если файл загружен

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_uploads")
}

// ─────────────────────────────────────────────
// Пользовательские аватары (кастомные, создаются через провайдеры)
// ─────────────────────────────────────────────
model UserAvatar {
  id         String   @id @default(cuid())
  userId     BigInt
  provider   String   // "heygen" | расширяется для других провайдеров
  name       String
  externalId String?  // talking_photo_id (заполняется когда аватар готов)
  previewUrl String?
  status     String   @default("creating") // "creating" | "ready" | "failed"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, provider])
  @@map("user_avatars")
}

// ─────────────────────────────────────────────
// Баннерные слайды
// ─────────────────────────────────────────────
model BannerSlide {
  id             String  @id @default(cuid())
  imageUrl       String
  linkUrl        String?
  displaySeconds Int     @default(4)
  sortOrder      Int     @default(0)
  active         Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
  @@map("banner_slides")
}

// ─────────────────────────────────────────────
// Курс обмена (USDT/RUB)
// ─────────────────────────────────────────────
model ExchangeRate {
  pair      String   @id              // "USDT_RUB"
  rate      Decimal  @db.Decimal(12, 4)
  updatedAt DateTime @updatedAt

  @@map("exchange_rates")
}
