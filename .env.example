# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=                          # required — @BotFather token
WEBAPP_URL=https://your-domain.com  # optional — Mini App URL shown in bot menu

# ── Database & Cache ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://metabox:metabox_password@localhost:5432/metabox_db  # required
REDIS_URL=redis://localhost:6379    # required (add ?password=... if auth enabled)

# ── API Server ────────────────────────────────────────────────────────────────
API_PORT=3001                       # optional, default 3001
ADMIN_SECRET=                       # optional — protects /admin/* routes

# ── Observability ─────────────────────────────────────────────────────────────
NODE_ENV=development                # development | production | test
LOG_LEVEL=info                      # trace | debug | info | warn | error
SENTRY_DSN=                         # optional — Sentry error tracking DSN

# ── Docker (prod only) ────────────────────────────────────────────────────────
POSTGRES_USER=metabox
POSTGRES_PASSWORD=metabox_password
POSTGRES_DB=metabox_db
REDIS_PASSWORD=
GRAFANA_PASSWORD=admin

# ── AI Providers ──────────────────────────────────────────────────────────────
# GPT section
OPENAI_API_KEY=sk-...
OPENAI_ASSISTANT_ID=               # optional — for OpenAI Assistants API
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...
QWEN_API_KEY=                      # optional — Qwen / Alibaba Cloud

# Design / Image generation
FAL_API_KEY=                       # FAL.ai — Flux, SDXL, Midjourney proxy
REPLICATE_API_KEY=                 # Replicate — various image/video models

# Video generation
RUNWAY_API_KEY=                    # RunwayML Gen-3
LUMA_API_KEY=                      # Luma Dream Machine
HEYGEN_API_KEY=                    # HeyGen talking avatar
HEYGEN_AVATAR_ID=                  # HeyGen default avatar ID
DID_API_KEY=                       # D-ID talking head
DID_PRESENTER_URL=                 # D-ID presenter image URL

# Audio generation
ELEVENLABS_API_KEY=                # ElevenLabs TTS / voice clone / sound effects
