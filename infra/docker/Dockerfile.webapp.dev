# Dev-only webapp image: builds the Vite SPA and serves it via nginx so
# docker-compose can bring up a runnable container (prod uses Dockerfile.webapp
# which only extracts dist/ for CDN upload via CI and has no serving stage).

FROM node:20-alpine AS deps
RUN npm install -g pnpm
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY packages/webapp/package.json         ./packages/webapp/
COPY packages/shared-browser/package.json ./packages/shared-browser/
RUN pnpm install --frozen-lockfile

FROM node:20-alpine AS builder
RUN npm install -g pnpm
WORKDIR /app
COPY --from=deps /app/node_modules                         ./node_modules
COPY --from=deps /app/packages/webapp/node_modules         ./packages/webapp/node_modules
COPY --from=deps /app/packages/shared-browser/node_modules ./packages/shared-browser/node_modules
COPY . .
ARG VITE_API_BASE_URL=http://localhost:3001
ARG VITE_BOT_USERNAME
ARG VITE_LEARNING_URL
ARG VITE_METABOX_LANDING_URL
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_BOT_USERNAME=$VITE_BOT_USERNAME
ENV VITE_LEARNING_URL=$VITE_LEARNING_URL
ENV VITE_METABOX_LANDING_URL=$VITE_METABOX_LANDING_URL
RUN pnpm --filter @metabox/shared-browser build
RUN pnpm --filter @metabox/webapp build

FROM nginx:alpine AS runner
COPY --from=builder /app/packages/webapp/dist /usr/share/nginx/html
# SPA fallback: every non-file path routes to index.html so client-side
# routing works (?page=download, ?page=management, etc.).
RUN printf 'server {\n\
  listen 80;\n\
  server_name _;\n\
  root /usr/share/nginx/html;\n\
  index index.html;\n\
  location / { try_files $uri $uri/ /index.html; }\n\
}\n' > /etc/nginx/conf.d/default.conf
